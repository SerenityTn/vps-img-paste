# Copy this to ~/.config/hermes-img.env and fill in your host.
# This file is read by bin/hermes-img at runtime. Keep the real one OUT of git.

# SSH target (user@host or an ssh_config alias).
HERMES_VPS="user@your-vps-host"

# Absolute home dir on the remote host — used to build the path pasted into Hermes.
HERMES_REMOTE_HOME="/home/user"

# Remote directory (relative to the SSH login dir) where images are uploaded.
# HERMES_REMOTE_DIR="hermes-uploads"

# Path to pngpaste if not the Apple-Silicon Homebrew default.
# PNGPASTE="/opt/homebrew/bin/pngpaste"
