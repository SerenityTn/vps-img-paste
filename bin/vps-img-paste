#!/usr/bin/env bash
# Send the image on the Mac clipboard (or a full-screen screenshot) to a remote
# host over SSH, and manage the uploaded images.
#
# Subcommands:
#   (none) | upload   Upload clipboard image, or a screenshot if the clipboard
#                     has no image. Puts the remote path on the clipboard.
#   list              Print "SIZE<TAB>NAME" for each uploaded image, newest first.
#   fetch NAME        Download NAME to a temp dir and print its local path.
#   clean             Delete all uploaded images on the host; print the count.
#
# Configure the host in ~/.config/vps-img-paste.env (see vps-img-paste.env.example),
# or via VPS_HOST / VPS_REMOTE_HOME env vars.
set -euo pipefail

# --- config ------------------------------------------------------------------
CONF="${VPS_IMG_PASTE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/vps-img-paste.env}"
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF"

VPS="${VPS_HOST:-user@your-vps-host}"
REMOTE_HOME="${VPS_REMOTE_HOME:-/home/user}"
REMOTE_DIR="${VPS_REMOTE_DIR:-img-uploads}"
SSH_OPTS=(-o BatchMode=yes -o ConnectTimeout=6)

# Locate pngpaste across Homebrew prefixes / PATH (works on Apple Silicon + Intel).
if [ -z "${PNGPASTE:-}" ]; then
  for c in "$(command -v pngpaste 2>/dev/null || true)" /opt/homebrew/bin/pngpaste /usr/local/bin/pngpaste; do
    if [ -n "$c" ] && [ -x "$c" ]; then PNGPASTE="$c"; break; fi
  done
fi
PNGPASTE="${PNGPASTE:-/opt/homebrew/bin/pngpaste}"

notify() { osascript -e "display notification \"$2\" with title \"VPS Image Paste\" subtitle \"$1\"" >/dev/null 2>&1; }

# Snapshot the current clipboard (image or text) to $1, echo its type (png|txt|none).
snapshot_clipboard() {
  local dir="$1"
  if osascript -e 'get the clipboard as «class PNGf»' >/dev/null 2>&1 && osascript >/dev/null 2>&1 <<OSA
set thePng to (the clipboard as «class PNGf»)
set f to (open for access (POSIX file "$dir/clip.png") with write permission)
write thePng to f
close access f
OSA
  then echo png; return; fi
  if pbpaste > "$dir/clip.txt" 2>/dev/null && [ -s "$dir/clip.txt" ]; then echo txt; return; fi
  echo none
}

# After $1 seconds, if the clipboard is still our path ($2), put the snapshot
# ($3 type, $4 dir) back — so the icon's clipboard change is only temporary and
# the VPS link never lingers to be pasted into a Mac app. Meant to run detached.
restore_clipboard_after() {
  local secs="$1" expected="$2" type="$3" dir="$4"
  sleep "$secs"
  if [ "$(pbpaste 2>/dev/null || true)" = "$expected" ]; then
    case "$type" in
      png) osascript -e "set the clipboard to (read (POSIX file \"$dir/clip.png\") as «class PNGf»)" >/dev/null 2>&1 ;;
      txt) pbcopy < "$dir/clip.txt" ;;
      *)   printf '' | pbcopy ;;   # clipboard was empty before the click — clear the link
    esac
  fi
  rm -rf "$dir"
}

if [ "$VPS" = "user@your-vps-host" ]; then
  echo "✗ Not configured. Copy vps-img-paste.env.example to $CONF and set VPS_HOST." >&2
  notify "Not configured" "Set VPS_HOST in ~/.config/vps-img-paste.env"
  exit 2
fi

cmd="${1:-upload}"

case "$cmd" in
  upload)
    # --- grab clipboard image, else screenshot the main display --------------
    tmp="$(mktemp -t vpsimgpaste).png"
    trap 'rm -f "$tmp"' EXIT

    if [ ! -x "$PNGPASTE" ]; then
      echo "✗ pngpaste not found at $PNGPASTE (brew install pngpaste)." >&2
      notify "Missing pngpaste" "Run: brew install pngpaste"
      exit 3
    fi

    kind="clip"
    if ! "$PNGPASTE" "$tmp" 2>/dev/null; then
      # No clipboard image — fall back to a full-screen screenshot of the main display.
      if screencapture -x -t png "$tmp" 2>/dev/null && [ -s "$tmp" ]; then
        kind="shot"
      else
        echo "✗ No clipboard image, and screen capture failed." >&2
        echo "  Grant Screen Recording permission to VPS Image Paste, or copy an image first." >&2
        notify "Capture failed" "Grant Screen Recording permission, or copy an image."
        exit 1
      fi
    fi

    name="$kind-$(date +%Y%m%d-%H%M%S).png"
    if ! scp -q "${SSH_OPTS[@]}" "$tmp" "$VPS:$REMOTE_DIR/$name"; then
      # Upload dir may not exist yet — create it once and retry.
      ssh "${SSH_OPTS[@]}" "$VPS" "mkdir -p '$REMOTE_DIR'" 2>/dev/null || true
      if ! scp -q "${SSH_OPTS[@]}" "$tmp" "$VPS:$REMOTE_DIR/$name"; then
        notify "Upload failed" "Could not reach $VPS."
        echo "✗ scp to $VPS failed." >&2
        exit 4
      fi
    fi

    remote_path="$REMOTE_HOME/$REMOTE_DIR/$name"

    # Snapshot the clipboard, then put the path on it for the SSH paste. A detached
    # job restores the snapshot after a grace window so the link never lingers.
    grace="${VPS_CLIP_RESTORE_SECONDS:-60}"
    snapdir="$(mktemp -d -t vpsclip)"
    snaptype="$(snapshot_clipboard "$snapdir")"
    printf '%s' "$remote_path" | pbcopy
    if [ "$grace" -gt 0 ] 2>/dev/null; then
      restore_clipboard_after "$grace" "$remote_path" "$snaptype" "$snapdir" >/dev/null 2>&1 </dev/null &
      disown 2>/dev/null || true
    else
      rm -rf "$snapdir"
    fi

    label=$([ "$kind" = shot ] && echo "Screenshot" || echo "Image")
    echo "✓ Uploaded ($label) → $remote_path"
    echo "  Path is on your clipboard — Cmd+V it into your SSH session and send."
    notify "$label path copied — ⌘V to paste" "clipboard restores in ${grace}s"
    ;;

  list)
    ssh "${SSH_OPTS[@]}" "$VPS" \
      "mkdir -p '$REMOTE_DIR' && find '$REMOTE_DIR' -maxdepth 1 -type f -name '*.png' -printf '%T@\t%s\t%f\n' | sort -rn | cut -f2-"
    ;;

  fetch)
    name="$(basename "${2:?usage: vps-img-paste fetch NAME}")"
    dest="$(mktemp -d -t vpsimgpaste)/$name"
    scp -q "${SSH_OPTS[@]}" "$VPS:$REMOTE_DIR/$name" "$dest"
    echo "$dest"
    ;;

  clean)
    n="$(ssh "${SSH_OPTS[@]}" "$VPS" \
      "find '$REMOTE_DIR' -maxdepth 1 -type f -name '*.png' -printf '.' -delete 2>/dev/null | wc -c" | tr -d ' ')"
    echo "✓ Deleted ${n:-0} uploaded image(s) on $VPS."
    notify "Uploads cleaned" "Deleted ${n:-0} image(s) on the VPS."
    ;;

  *)
    echo "usage: vps-img-paste [upload|list|fetch NAME|clean]" >&2
    exit 64
    ;;
esac
