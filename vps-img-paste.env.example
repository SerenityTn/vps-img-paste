# Copy this to ~/.config/vps-img-paste.env and fill in your host.
# This file is read by bin/vps-img-paste at runtime. Keep the real one OUT of git.

# SSH target (user@host or an ssh_config alias).
VPS_HOST="user@your-vps-host"

# Absolute home dir on the remote host — used to build the path you paste.
VPS_REMOTE_HOME="/home/user"

# Remote directory (relative to the SSH login dir) where images are uploaded.
# VPS_REMOTE_DIR="img-uploads"

# Path to pngpaste if not the Apple-Silicon Homebrew default.
# PNGPASTE="/opt/homebrew/bin/pngpaste"
